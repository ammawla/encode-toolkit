// ENCODE ATAC-seq Pipeline Configuration
// Profiles: local (Docker), slurm (Singularity), gcp, aws

params {
    max_cpus   = 16
    max_memory = '64.GB'
    max_time   = '24.h'
}

profiles {
    local {
        docker.enabled = true
        process {
            container = 'encodedcc/atac-seq-pipeline:v2.2.0'
            cpus   = 4
            memory = '16.GB'
            withName: 'BOWTIE2_ALIGN'    { cpus = 8;  memory = '32.GB' }
            withName: 'MARK_DUPLICATES'  { cpus = 2;  memory = '16.GB' }
            withName: 'TN5_SHIFT'        { cpus = 4;  memory = '16.GB' }
            withName: 'NFR_SELECTION'    { cpus = 4;  memory = '8.GB'  }
            withName: 'MACS2_CALLPEAK'   { cpus = 2;  memory = '8.GB'  }
            withName: 'SIGNAL_TRACKS'    { cpus = 4;  memory = '8.GB'  }
            withName: 'MULTIQC'          { cpus = 1;  memory = '4.GB'  }
        }
    }

    slurm {
        singularity.enabled    = true
        singularity.autoMounts = true
        process {
            container = 'docker://encodedcc/atac-seq-pipeline:v2.2.0'
            executor  = 'slurm'
            queue     = 'normal'
            cpus      = 4
            memory    = '16.GB'
            time      = '4.h'
            withName: 'BOWTIE2_ALIGN'    { cpus = 8;  memory = '32.GB'; time = '8.h'  }
            withName: 'MARK_DUPLICATES'  { cpus = 4;  memory = '16.GB'; time = '4.h'  }
            withName: 'TN5_SHIFT'        { cpus = 4;  memory = '16.GB'; time = '2.h'  }
            withName: 'NFR_SELECTION'    { cpus = 4;  memory = '8.GB';  time = '2.h'  }
            withName: 'MACS2_CALLPEAK'   { cpus = 2;  memory = '8.GB';  time = '2.h'  }
            withName: 'SIGNAL_TRACKS'    { cpus = 4;  memory = '8.GB';  time = '2.h'  }
            withName: 'MULTIQC'          { cpus = 1;  memory = '4.GB';  time = '1.h'  }
        }
    }

    gcp {
        docker.enabled = true
        process {
            container = 'encodedcc/atac-seq-pipeline:v2.2.0'
            executor  = 'google-lifesciences'
            cpus      = 4
            memory    = '16.GB'
            disk      = '100.GB'
            withName: 'BOWTIE2_ALIGN'    { cpus = 8;  memory = '32.GB'; disk = '200.GB'; machineType = 'n1-standard-8' }
            withName: 'MARK_DUPLICATES'  { cpus = 4;  memory = '16.GB'; disk = '100.GB' }
            withName: 'TN5_SHIFT'        { cpus = 4;  memory = '16.GB' }
            withName: 'SIGNAL_TRACKS'    { cpus = 4;  memory = '8.GB' }
        }
        google {
            project     = params.gcp_project ?: 'my-project'
            region      = params.gcp_region  ?: 'us-central1'
            preemptible = true
        }
    }

    aws {
        docker.enabled = true
        process {
            container = 'encodedcc/atac-seq-pipeline:v2.2.0'
            executor  = 'awsbatch'
            queue     = params.aws_queue ?: 'default'
            cpus      = 4
            memory    = '16.GB'
            withName: 'BOWTIE2_ALIGN'    { cpus = 8;  memory = '32.GB' }
            withName: 'MARK_DUPLICATES'  { cpus = 4;  memory = '16.GB' }
            withName: 'TN5_SHIFT'        { cpus = 4;  memory = '16.GB' }
        }
        aws {
            region = params.aws_region ?: 'us-east-1'
            batch {
                cliPath = '/home/ec2-user/miniconda/bin/aws'
                volumes = '/tmp'
            }
        }
    }
}

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.svg"
}
